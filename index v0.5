    // Función para obtener icono y estilo según la complejidad del hospital
    function getHospitalConfig(name) {
      const n = (name || "").toUpperCase().trim();
      if (n === 'HHHA') {
        return { icon: 'building-2', size: 'w-7 h-7', label: 'Alta', color: 'text-medical-dark' };
      }
      const mediana = ['HVILLA', 'HINI', 'HLAUTA', 'CAPLC'];
      if (mediana.some(h => n.includes(h))) {
        return { icon: 'hospital', size: 'w-5 h-5', label: 'Mediana', color: 'text-medical-primary' };
      }
      return { icon: 'home', size: 'w-4 h-4', label: 'Baja', color: 'text-slate-500' };
    }

  

