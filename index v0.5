      </div>
      <div class="w-full mb-8">
        <input type="password" id="login-input-pass" placeholder="Contraseña" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-medical-primary outline-none">
