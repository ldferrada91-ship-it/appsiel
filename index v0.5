        const modal = document.getElementById('user-modal');
        if (!modal) {
            alert("Error: No se encontró el código HTML del modal.");
            return;
        }
        
        modal.classList.remove('hidden');
        
        if (email && email !== 'undefined') {
            const u = db.usuarios.find(x => x.email === email);
            if(u) {
                document.getElementById('user-modal-title').innerText = "Editar Usuario";
                document.getElementById('usr-original-email').value = u.email;
                document.getElementById('usr-email').value = u.email;
                document.getElementById('usr-role').value = u.role;
                document.getElementById('usr-sede').value = u.sede;
            }
        } else {
            document.getElementById('user-modal-title').innerText = "Nuevo Usuario";
            document.getElementById('usr-original-email').value = '';
            document.getElementById('usr-email').value = '';
            document.getElementById('usr-role').value = 'LECTOR';
            document.getElementById('usr-sede').value = '';
        }
    }

