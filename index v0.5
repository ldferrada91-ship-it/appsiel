<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Portal SIEL SSASUR v0.5</title>
  
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
  <script src="https://unpkg.com/lucide@latest"></script>
  <link rel="shortcut icon" href="data:image/x-icon;," type="image/x-icon"> 
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  
  <script>
    tailwind.config = { theme: { extend: { fontFamily: { sans: ['Inter', 'sans-serif'] }, colors: { medical: { primary: '#0284c7', dark: '#0c4a6e', light: '#e0f2fe', critical: '#ef4444' } } } } }
  </script>
  <style>
    body { background: radial-gradient(circle at top right, #f1f5f9, #e0f2fe); min-height: 100vh; font-feature-settings: "cv02", "cv03", "cv04", "cv11"; }
    .glass { background: rgba(255, 255, 255, 0.65); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.8); box-shadow: 0 8px 32px 0 rgba(2, 132, 199, 0.05); }
    .glass-card { background: linear-gradient(135deg, rgba(255,255,255,0.9) 0%, rgba(255,255,255,0.6) 100%); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.5); }
    .custom-scroll::-webkit-scrollbar { width: 6px; height: 6px; }
    .custom-scroll::-webkit-scrollbar-track { background: transparent; }
    .custom-scroll::-webkit-scrollbar-thumb { background: #94a3b8; border-radius: 10px; }
    .pulse-glow { animation: pulseGlow 2.5s infinite cubic-bezier(0.4, 0, 0.6, 1); }
    @keyframes pulseGlow { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: .8; transform: scale(1.02); } }
    
    /* Reglas para imprimir a PDF de forma limpia */
    .pdf-mode { background: white !important; }
  </style>
</head>
<body class="text-slate-800 antialiased overflow-hidden selection:bg-medical-light selection:text-medical-dark">

  <div id="full-loader" class="fixed inset-0 z-[100] glass flex flex-col items-center justify-center transition-all duration-700">
