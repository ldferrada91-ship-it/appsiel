        <i data-lucide="shield-check" class="w-10 h-10"></i>
      </div>
      <h2 class="text-3xl font-black text-medical-dark mb-1 text-center leading-none">Credenciales de acceso</h2>
      <div class="w-full mb-4 mt-8">
