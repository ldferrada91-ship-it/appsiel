    function confirmModalChanges() {
        const id = document.getElementById('edit-id').value;
        if(!changes[id]) changes[id] = {'Número': id};
        
        // Mapeamos los campos del modal al objeto de cambios
        changes[id]['Nombre exámen SIEL'] = document.getElementById('edit-nombre').value;
        changes[id]['Area de trabajo'] = document.getElementById('edit-area').value;
        changes[id]['Código FONASA'] = document.getElementById('edit-fonasa').value;
        changes[id]['Código LOINC'] = document.getElementById('edit-loinc').value;
        changes[id]['Utilidad clinica'] = document.getElementById('edit-utilidad').value;
        changes[id]['Valores referencia'] = document.getElementById('edit-valores').value;

        // Actualizamos visualmente el botón de guardado maestro
        const btns = document.querySelectorAll('.save-btn');
        btns.forEach(btn => { 
            btn.classList.remove('opacity-50', 'cursor-not-allowed'); 
            btn.classList.add('bg-amber-500', 'pulse-glow'); 
            btn.innerText = "Sincronizar cambios detectados"; 
        });

        closeEditModal();
        alert("Cambios preparados localmente para el examen " + id + ". Recuerde sincronizar a Sheets al finalizar.");
    }

    function markChange(id, field, value) {
      if(!changes[id]) changes[id] = {'Número': id};
      changes[id][field] = value;
      const btns = document.querySelectorAll('.save-btn');
      btns.forEach(btn => { btn.classList.remove('opacity-50', 'cursor-not-allowed'); btn.classList.add('bg-amber-500'); btn.innerText = "Guardar cambios"; });
    }

    function saveChanges() {
      const datos = Object.values(changes);
      google.script.run.withSuccessHandler(() => location.reload()).guardarEdicionMasiva(datos);
    }


