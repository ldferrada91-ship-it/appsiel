      <i data-lucide="microscope" class="w-12 h-12 text-white"></i>
    </div>
    <h2 class="text-xl font-black text-medical-dark tracking-widest uppercase">Inicializando SIEL SSASUR...</h2>
  </div>

  <div id="login-view" class="fixed inset-0 z-[90] glass hidden flex flex-col items-center justify-center transition-all duration-500 opacity-0">
