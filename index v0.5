        const email = document.getElementById('usr-email').value.trim();
        const role = document.getElementById('usr-role').value;
        const sede = document.getElementById('usr-sede').value.trim();

        if(!email) return alert("El correo es obligatorio.");

        // Si estamos editando, borramos el original temporalmente
        if (origEmail) {
            db.usuarios = db.usuarios.filter(u => u.email !== origEmail);
        }
        
        // Verificamos que no haya duplicados
        if (db.usuarios.some(u => u.email === email)) {
            alert("Este correo ya está registrado.");
            return;
        }

        // Guardamos el usuario
        db.usuarios.push({ email, role, sede });
        closeUserModal();
        renderUsers(); // Refrescamos la tabla
    }

    function deleteUser(email) {
        if(confirm(`¿Estás seguro de eliminar el acceso para ${email}?`)) {
            db.usuarios = db.usuarios.filter(u => u.email !== email);
            renderUsers(); // Refrescamos la tabla
        }
    }

    // Función para cambiar entre las pantallas del sistema
    function nav(tab) {
        // Definimos las 3 pestañas que existen: Catálogo (cat), Gestor (edt) y Usuarios (usr)
        const tabs = ['cat', 'edt', 'usr'];
        
        tabs.forEach(t => {
            const btn = document.getElementById(`tab-${t}`);
            const view = document.getElementById(`view-${t}`);
            
            // Si el botón y la vista existen en el HTML, aplicamos los cambios
            if (btn && view) {
                if (t === tab) {
                    // Pestaña ACTIVA: Le damos fondo blanco y texto azul
                    btn.classList.add('bg-white', 'text-medical-primary', 'shadow-sm');
                    btn.classList.remove('text-slate-500');
                    view.classList.remove('hidden'); // Mostramos la pantalla
                } else {
                    // Pestaña INACTIVA: Le quitamos el fondo y la ponemos gris
                    btn.classList.remove('bg-white', 'text-medical-primary', 'shadow-sm');
                    btn.classList.add('text-slate-500');
                    view.classList.add('hidden'); // Ocultamos la pantalla
                }
            }
        });
        
        // Si el usuario acaba de entrar a la pestaña de Usuarios, dibujamos la tabla
        if (tab === 'usr' && typeof renderUsers === 'function') {
            renderUsers();
        }
    }
     

  </script>
</body>
</html>
