  <script>
    let db = { examenes: [], red: [] }, changes = {}, user = { email: '', role: '' };
    let currentEditId = null;

    // Inicializar Lucide Icons
    window.addEventListener('DOMContentLoaded', () => { lucide.createIcons(); });

    // Función Segura para leer columnas (ignora espacios)
    function getSafeField(obj, exactKey) {
       if(!obj) return '';
       if(obj[exactKey] !== undefined && obj[exactKey] !== '') return obj[exactKey];
       const target = exactKey.trim().toLowerCase();
       for(let k in obj) { if(k.trim().toLowerCase() === target || k.trim().toLowerCase().includes(target)) return obj[k]; }
       return '';
    }
     

    // Parser Inteligente de Condiciones Preanalíticas
    function parsearCondiciones(texto) {
      if (!texto || texto.toUpperCase() === 'SIN INFORMACION') {
          return {
              paciente: `No requiere preparación especial. 
Ayuno estándar sugerido.`, // <-- Usar backticks
              conservacion: 'Conservar según estándar de la red.',
              transporte: `Temperatura ambiente. 
Enviar antes de 2 horas.` // <-- Usar backticks
          };
      }
      // ... resto del código del parser ...
      let prep = texto, cons = 'Ver información principal.', trans = 'Ver información principal.';
      if (texto.includes('1.') || texto.includes('2.') || texto.toUpperCase().includes('CONSERVACION')) {
          try {
              let partes1 = texto.split(/(?:2\.\s*CONSERVACION:|2\.\s*CONSERVACIÓN:|2\.)/i);
              prep = partes1[0].replace(/(?:1\.\s*PREPARACION DEL PACIENTE:|1\.\s*PREPARACIÓN DEL PACIENTE:|1\.)/i, '').trim();
              if (partes1.length > 1) {
                  let partes2 = partes1[1].split(/(?:3\.\s*TRANSPORTE:|3\.)/i);
                  cons = partes2[0].trim();
                  if (partes2.length > 1) trans = partes2[1].trim();
              }
          } catch(e) {}
      }
      return { paciente: prep, conservacion: cons, transporte: trans };
    }

    // Exportación a PDF
    function exportarPDF() {
        const elemento = document.getElementById('detail-panel');
        const boton = elemento.querySelector('button');

        // 1. Ocultamos el botón temporalmente
        if (boton) boton.style.display = 'none';

        // 2. Configuración básica y estable
        const opt = {
            margin:       10,
            filename:     'Ficha_Examen_SIEL.pdf',
            image:        { type: 'jpeg', quality: 0.98 },
            html2canvas:  { scale: 2 }, // Toma la foto tal cual se ve en pantalla
            jsPDF:        { unit: 'mm', format: 'letter', orientation: 'portrait' }
        };

        // 3. Generar PDF directo del elemento visible
        html2pdf().set(opt).from(elemento).save().then(() => {
            // 4. Volver a mostrar el botón tras la descarga
            if (boton) boton.style.display = 'flex';
        });
    }

    // Carga Inicial
    window.onload = () => {
      google.script.run.withSuccessHandler(res => {
        const payload = JSON.parse(res);
        db.examenes = payload.examenes;
        db.red = payload.red;
        db.usuarios = payload.usuarios; // <--- ASIGNACIÓN DE USUARIOS REALES [cite: 52, 68]
        document.getElementById('full-loader').classList.add('hidden');
        document.getElementById('login-view').classList.remove('hidden');
        setTimeout(() => document.getElementById('login-view').classList.remove('opacity-0'), 50);
      }).getInitData();
    };

    function intentarLogin() {
      const email = document.getElementById('login-input-email').value;
      const pass = document.getElementById('login-input-pass').value;
      google.script.run.withSuccessHandler(res => {
        if (res.success) { user = { email: email, role: res.role }; entrarAlPortal(); } 
        else { document.getElementById('login-error').innerText = res.msg; document.getElementById('login-error').classList.remove('hidden'); }
      }).verificarLogin(email, pass);
    }

    function entrarAlPortal() {
      document.getElementById('login-view').classList.add('hidden');
      document.getElementById('main-header').classList.remove('hidden');
      document.getElementById('header-email').innerText = user.email.split('@')[0];
      document.getElementById('header-role').innerText = user.role;
      if(user.role === "ADMIN") document.getElementById('tab-edt').classList.remove('hidden');
      populateFilters(); applyFilters(); nav('cat');
    }

    function cerrarSesion() { location.reload(); }

  

    function populateFilters() {
      const getUnique = (arr, key) => [...new Set(arr.map(x => getSafeField(x, key)).filter(x => x && x.trim() !== ''))].sort();
      
      getUnique(db.examenes, 'Area de trabajo').forEach(v => document.getElementById('filt-area').innerHTML += `<option value="${v}">${v}</option>`);
      getUnique(db.examenes, 'Tipo muestra').forEach(v => document.getElementById('filt-muestra').innerHTML += `<option value="${v}">${v}</option>`);
      getUnique(db.examenes, 'Contenedor').forEach(v => document.getElementById('filt-cont').innerHTML += `<option value="${v}">${v}</option>`);
      
      const selectSede = document.getElementById('filt-sede');
      getUnique(db.red, 'Hospital').forEach(v => {
          const opt = document.createElement('option');
          opt.value = v; opt.innerText = v; opt.className = "text-slate-800";
          selectSede.appendChild(opt);
      });
    }

    function applyFilters() {
      const q = document.getElementById('search').value.toLowerCase();
      const a = document.getElementById('filt-area').value;
      const m = document.getElementById('filt-muestra').value;
      const c = document.getElementById('filt-cont').value;
      
      const res = db.examenes.filter(ex => {
        const nom = getSafeField(ex, 'Nombre exámen SIEL').toLowerCase();
        const num = getSafeField(ex, 'Número').toLowerCase();
        const loinc = getSafeField(ex, 'Código LOINC').toLowerCase();
        const fonasa = getSafeField(ex, 'Código FONASA').toLowerCase();
        const area = getSafeField(ex, 'Area de trabajo');
        const mues = getSafeField(ex, 'Tipo muestra');
        const cont = getSafeField(ex, 'Contenedor');
        
        return (nom.includes(q) || num.includes(q) || loinc.includes(q) || fonasa.includes(q)) && (!a || area === a) && (!m || mues === m) && (!c || cont === c);
      });
      renderCatalog(res); 
      if(user.role === "ADMIN") renderEditor(res);
    }

